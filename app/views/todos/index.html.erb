<div class="mx-auto w-1/2">
  <h2 class="text-2xl text-gray-900">
    Your todos
  </h2>
  <%= turbo_frame_tag "todos-container", class: "block max-w-2xl w-full bg-gray-100 py-8 px-4 border border-gray-200 rounded shadow-sm" do %>
    <div class="border-b border-gray-200 w-full">
      <ul class="flex space-x-2 justify-center">
        <li class="me-2">
          <%= link_to "Incomplete", todos_path(status: "incomplete"), class: (params[:status] == 'complete' ? 'unselected-tab' : 'selected-tab') %>
        <li>
        <%= link_to "Complete", todos_path(status: "complete"), class: (params[:status] != 'complete' ? 'unselected-tab' : 'selected-tab')  %>
        </li>
      </ul>
    </div>
    <% unless params[:status] == "complete" %>
      <div class="py-2 px-4">
        <%= render "form", todo: Todo.new %>
      </div>
    <% end %>
    <ul id="todos">
      <%= render @todos %>
    </ul>
  <% end %>
</div>

